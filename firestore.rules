rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: user owns the document
    function isOwner() {
      return isAuth() && request.auth.uid == resource.data.ownerId;
    }

    // Helper: user is setting themselves as owner on create
    function isCreatingOwn() {
      return isAuth() && request.auth.uid == request.resource.data.ownerId;
    }

    // Leads
    match /leads/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Contacts
    match /contacts/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Activities
    match /activities/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Tasks
    match /tasks/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }
  }
}
