rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: user owns the document
    function isOwner() {
      return isAuth() && request.auth.uid == resource.data.ownerId;
    }

    // Helper: user is setting themselves as owner on create
    function isCreatingOwn() {
      return isAuth() && request.auth.uid == request.resource.data.ownerId;
    }

    // Leads
    match /leads/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Contacts
    match /contacts/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Activities
    match /activities/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Tasks
    match /tasks/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Transactions
    match /transactions/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Show Days
    match /showDays/{docId} {
      allow read: if true; // public read for QR code form
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Show Day Leads (public write for registration — schema validated)
    match /showDayLeads/{docId} {
      allow read: if isAuth();
      allow create: if
        request.resource.data.keys().hasAll(["showDayId", "name", "email", "phone", "marketingConsent"]) &&
        request.resource.data.showDayId is string &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 200 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() <= 254 &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() <= 30 &&
        request.resource.data.marketingConsent is bool &&
        request.resource.data.keys().size() <= 10;
    }

    // Properties / Mandates
    match /properties/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Inbound Leads (Portal Injection)
    match /inboundLeads/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // SMS Messages
    match /smsMessages/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Follow-up Sequences
    match /followUpSequences/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Sequence Enrollments
    match /sequenceEnrollments/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Buyer Profiles
    match /buyerProfiles/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Documents
    match /documents/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Auto-Response Rules (Speed-to-Lead)
    match /autoResponseRules/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // CMA Reports
    match /cmaReports/{docId} {
      allow read: if isAuth();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner();
    }

    // Agent Profiles — keyed by Firebase Auth uid.
    // Read: any signed-in user (so colleagues can see each other's contact card).
    // Write: owner only — `uid` field must match auth uid.
    match /agentProfiles/{uid} {
      allow read: if isAuth();
      allow create, update: if isAuth() && request.auth.uid == uid && request.resource.data.uid == uid;
      allow delete: if isAuth() && request.auth.uid == uid;
    }

    // Rate-limit counters — server-only via Admin SDK.
    // Clients must never read or write these documents.
    match /rateLimits/{docId} {
      allow read, write: if false;
    }
  }
}
